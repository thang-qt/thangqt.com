---
const footerLinks = [
  { label: 'GitHub', href: 'https://github.com/yourusername', target: '_blank' },
  { label: 'Twitter', href: 'https://twitter.com/yourusername', target: '_blank' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/yourusername', target: '_blank' },
  { label: 'Email', href: 'mailto:your@email.com' },
];
---

<div class="footer-links">
  {footerLinks.map(({ label, href, target }) => (
    <a 
      href={href} 
      class="footer-link"
      target={target}
      rel={target === '_blank' ? 'noopener noreferrer' : undefined}
    >
      {label}
    </a>
  ))}
</div>
