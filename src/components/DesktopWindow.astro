---
interface Props {
  title: string;
  class?: string;
  variant?: 'primary' | 'mini' | 'paper';
  minWidth?: number;
  minHeight?: number;
  maxWidth?: number;
  maxHeight?: number;
  resizable?: boolean;
  maximizable?: boolean;
  windowTokens?: {
    light: Record<string, string>;
    dark: Record<string, string>;
  };
  [key: string]: unknown;
}

const {
  title,
  class: className = '',
  variant = 'primary',
  minWidth,
  minHeight,
  maxWidth,
  maxHeight,
  resizable = true,
  maximizable = true,
  windowTokens,
  ...attrs
} = Astro.props;
---

<section
  class={`desktop-window desktop-window--${variant} ${className}`.trim()}
  data-window-min-width={minWidth}
  data-window-min-height={minHeight}
  data-window-max-width={maxWidth}
  data-window-max-height={maxHeight}
  data-window-resizable={resizable ? 'true' : 'false'}
  data-window-maximizable={maximizable ? 'true' : 'false'}
  data-window-tokens={windowTokens ? JSON.stringify(windowTokens) : undefined}
  {...attrs}
>
  <header class="desktop-window__bar">
    <h2>{title}</h2>
    <div class="desktop-window__controls">
      <button type="button" data-window-action="minimize" aria-label="Minimize"></button>
      <button type="button" data-window-action="maximize" aria-label="Maximize"></button>
      <button type="button" data-window-action="close" aria-label="Close"></button>
    </div>
  </header>
  <div class="desktop-window__body">
    <slot />
  </div>
</section>
