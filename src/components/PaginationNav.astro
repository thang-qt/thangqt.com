---
import { buildPageHref } from '../utils/pagination';

interface Props {
  basePath: string;
  currentPage: number;
  totalPages: number;
  label: string;
}

const { basePath, currentPage, totalPages, label } = Astro.props;

const prevHref = currentPage > 1 ? buildPageHref(basePath, currentPage - 1) : null;
const nextHref = currentPage < totalPages ? buildPageHref(basePath, currentPage + 1) : null;
---

{totalPages > 1 && (
  <nav class="list-pagination" aria-label={label}>
    {prevHref ? (
      <a href={prevHref} class="list-pagination-link list-pagination-link-prev" aria-label="Go to newer page">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" />
        </svg>
      </a>
    ) : (
      <span class="list-pagination-link list-pagination-link-prev is-disabled" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" />
        </svg>
      </span>
    )}

    {nextHref ? (
      <a href={nextHref} class="list-pagination-link list-pagination-link-next" aria-label="Go to older page">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18l6-6-6-6" />
        </svg>
      </a>
    ) : (
      <span class="list-pagination-link list-pagination-link-next is-disabled" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18l6-6-6-6" />
        </svg>
      </span>
    )}
  </nav>
)}
