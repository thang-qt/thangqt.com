---
import Layout from '../layouts/Layout.astro';
import {
  formatLinkDate,
  formatLinkKind,
  getHostnameLabel,
  getLinkHref,
  getLinkTitle,
  getPublishedLinks,
  resolveVia,
} from '../utils/links';

const { links, slugMap } = await getPublishedLinks();

const linksWithVia = links.map((link) => ({
  link,
  via: resolveVia(link.data.via, slugMap),
}));
---

<Layout title="Links - ThangQT" description="A public bookmark archive of things I want to remember.">
  <section class="col-main links-list-column" transition:name="col-main" transition:animate="fade">
    <div class="list-mobile-header">
      <h1 class="list-page-title">Links</h1>
    </div>

    {linksWithVia.length === 0 ? (
      <div class="links-empty-state">
        <p>No links yet.</p>
        <p>Add entries in <code>src/content/links/</code> with a <code>slug</code> and <code>url</code>.</p>
      </div>
    ) : (
      <div class="links-list">
        {linksWithVia.map(({ link, via }) => (
          <article class="link-item" data-preview-trigger={link.slug}>
            <div class="link-item-main">
              <h2 class="link-title">
                <a href={link.data.url} class="link-title-link" target="_blank" rel="noreferrer">
                  {getLinkTitle(link)}
                </a>
              </h2>

              <p class="link-meta">
                <span>{getHostnameLabel(link.data.url)}</span>
                {formatLinkKind(link.data.kind) && <span>{formatLinkKind(link.data.kind)}</span>}
                {formatLinkDate(link.data.date) && <span>{formatLinkDate(link.data.date)}</span>}
              </p>

              {link.data.note && <p class="link-note">{link.data.note}</p>}

              {via.length > 0 && (
                <p class="link-via">
                  <span>via</span>
                  {via.map((item) => (
                    <span class="link-via-item">
                      <a href={item.href} class="link-inline" target={item.type === 'external' ? '_blank' : undefined} rel={item.type === 'external' ? 'noreferrer' : undefined}>
                        {item.label}
                      </a>
                    </span>
                  ))}
                </p>
              )}

              {link.data.tags && link.data.tags.length > 0 && (
                <ul class="link-tags" aria-label="Tags">
                  {link.data.tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              )}
            </div>

            <a href={getLinkHref(link)} class="link-permalink link-permalink-icon" aria-label={`Open permalink for ${getLinkTitle(link)}`}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M10 13a5 5 0 0 0 7.07 0l2.83-2.83a5 5 0 0 0-7.07-7.07L11.2 4.72" />
                <path d="M14 11a5 5 0 0 0-7.07 0L4.1 13.83a5 5 0 1 0 7.07 7.07L12.8 19.28" />
              </svg>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>

  <aside class="col-sidebar link-preview-sidebar" transition:name="col-sidebar" transition:animate="fade">
    <div class="is-visible links-preview-shell">
      <div class="link-preview-panel is-active">
        <p class="link-preview-stamp">Stay curious.</p>
      </div>
    </div>
  </aside>
</Layout>
