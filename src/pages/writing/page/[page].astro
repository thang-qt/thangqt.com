---
import Layout from '../../../layouts/Layout.astro';
import PaginationNav from '../../../components/PaginationNav.astro';
import { getPublishedWriting } from '../../../utils/collections';
import {
  formatShortDate,
  getPaginationStaticPaths,
  paginateItems,
  parsePageParam,
  WRITING_PAGE_SIZE,
} from '../../../utils/pagination';

export async function getStaticPaths() {
  const posts = await getPublishedWriting();
  return getPaginationStaticPaths(posts.length, WRITING_PAGE_SIZE);
}

const currentPage = parsePageParam(Astro.params.page);
const posts = await getPublishedWriting();
const paginatedPosts = paginateItems(posts, currentPage, WRITING_PAGE_SIZE);
---

<Layout
  title={`Writing - Page ${paginatedPosts.currentPage} - ThangQT`}
  description="My various thoughts on life, tech, and everything in between"
>
  <section class="col-content archive-page archive-page--writing" data-window-title="Writing">
    <header class="archive-hero">
      <h1>Writing</h1>
    </header>

    <div class="writing-ledger" aria-label="Writing archive">
      {
        paginatedPosts.items.map((post) => (
          <article class="ledger-row">
            <a
              href={`/writing/${post.slug}`}
              class="ledger-row__link"
              data-window-title={post.data.title}
            >
              <div class="ledger-row__meta">
                <time datetime={post.data.date.toISOString()}>
                  {formatShortDate(post.data.date)}
                </time>
              </div>
              <div class="ledger-row__body">
                <h2>{post.data.title}</h2>
              </div>
            </a>
          </article>
        ))
      }
    </div>

    <PaginationNav
      basePath="/writing"
      currentPage={paginatedPosts.currentPage}
      totalPages={paginatedPosts.totalPages}
      label="Writing pagination"
    />
  </section>
</Layout>
