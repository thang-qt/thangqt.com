---
import Layout from '../../../layouts/Layout.astro';
import PaginationNav from '../../../components/PaginationNav.astro';
import { getPublishedWriting } from '../../../utils/collections';
import {
  formatShortDate,
  getPaginationStaticPaths,
  paginateItems,
  parsePageParam,
  WRITING_PAGE_SIZE,
} from '../../../utils/pagination';

export async function getStaticPaths() {
  const posts = await getPublishedWriting();
  return getPaginationStaticPaths(posts.length, WRITING_PAGE_SIZE);
}

const currentPage = parsePageParam(Astro.params.page);
const posts = await getPublishedWriting();
const paginatedPosts = paginateItems(posts, currentPage, WRITING_PAGE_SIZE);
---

<Layout title={`Writing - Page ${paginatedPosts.currentPage} - ThangQT`} description="My various thoughts on life, tech, and everything in between">
  <section class="col-content list-app list-app--writing" data-window-title="Writing">
    <div class="list-mobile-header">
      <div>
        <p class="list-kicker">Journal index</p>
        <h1 class="list-page-title">Writing</h1>
      </div>
      <div class="list-toolbar" aria-label="Writing display options">
        <span>View</span>
        <button type="button" data-list-view="list">List</button>
        <button type="button" data-list-view="grid">Grid</button>
        <button type="button" data-list-view="compact">Compact</button>
      </div>
    </div>
    <p class="list-status">{paginatedPosts.totalItems} posts sorted by newest first.</p>

    {paginatedPosts.items.map((post) => (
      <article class="post-item">
        <a href={`/writing/${post.slug}`} class="list-link" data-window-title={post.data.title}>
          <span class="list-row-main">
            <h2 class="post-title">{post.data.title}</h2>
            {post.data.description && <p class="list-description">{post.data.description}</p>}
          </span>
          <span class="post-meta">{formatShortDate(post.data.date)}</span>
        </a>
      </article>
    ))}

    <PaginationNav
      basePath="/writing"
      currentPage={paginatedPosts.currentPage}
      totalPages={paginatedPosts.totalPages}
      label="Writing pagination"
    />
  </section>

  <aside class="col-detail">
    <div class="is-visible">
      <h2>Writing</h2>
    </div>
  </aside>
</Layout>
