---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image, getImage } from 'astro:assets';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const coverMode = post.data.coverMode ?? 'inline';
const contentBackground = post.data.contentBackground;
const themeColor = post.data.themeColor;
const themeColorDark = post.data.themeColorDark;

// Get optimized cover image URL for background usage
const coverBgImage = post.data.cover && coverMode === 'title-background'
  ? await getImage({ src: post.data.cover, width: 1920 })
  : null;

// Get cover image URL for OG image
const ogImageUrl = post.data.cover
  ? (await getImage({ src: post.data.cover, width: 1200 })).src
  : undefined;

const bodyClass = [
  'page-post',
  contentBackground ? 'has-content-bg' : '',
  themeColor ? 'has-theme-bg' : '',
]
  .filter(Boolean)
  .join(' ');

const bodyStyle = [
  contentBackground ? `--post-content-bg-url: url('${contentBackground}')` : '',
  themeColor ? `--post-theme-bg: ${themeColor}` : '',
  themeColorDark ? `--post-theme-bg-dark: ${themeColorDark}` : '',
]
  .filter(Boolean)
  .join('; ');

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<Layout
  title={`${post.data.title} - ThangQT`}
  description={post.data.description || post.data.title}
  bodyClass={bodyClass}
  bodyStyle={bodyStyle || undefined}
  ogImage={ogImageUrl}
  ogType="article"
  publishedDate={post.data.date}
  tags={post.data.tags}
  jsonLdType="article"
>
  <section
    class:list={['col-content post-header', coverMode === 'title-background' ? 'has-title-bg' : '']}
    style={coverBgImage ? `--post-cover-url: url('${coverBgImage.src}')` : undefined}
    transition:name="col-content"
    transition:animate="fade"
  >
    <a href="/writing" class="back-link" aria-label="Back to writing">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      <span>Back</span>
    </a>
    <div class="post-header-content">
      <p class="post-page-date">{formatDate(post.data.date)}</p>
      <h1 class="post-page-title">{post.data.title}</h1>
    </div>
  </section>

  <aside
    class:list={['col-detail post-body', contentBackground ? 'has-content-bg' : '']}
    style={contentBackground ? `--post-content-bg-url: url('${contentBackground}')` : undefined}
    transition:name="col-detail"
    transition:animate="fade"
  >
    <div class="post-mobile-header">
      <p class="post-page-date">{formatDate(post.data.date)}</p>
      <h1 class="post-page-title">{post.data.title}</h1>
    </div>
    {post.data.cover && (
      <figure class="post-cover">
        <Image src={post.data.cover} alt={post.data.title} />
      </figure>
    )}
    <article class="prose">
      <Content />
    </article>
  </aside>
</Layout>
