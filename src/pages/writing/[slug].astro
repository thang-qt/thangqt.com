---
import Layout from '../../layouts/Layout.astro';
import { Image, getImage } from 'astro:assets';
import { getFirstContentImage } from '../../utils/contentImages';
import { getPublishedWriting } from '../../utils/collections';
import { formatShortDate } from '../../utils/pagination';

export async function getStaticPaths() {
  const posts = await getPublishedWriting();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const contentBackground = post.data.contentBackground;
const themeColor = post.data.themeColor;
const themeColorDark = post.data.themeColorDark;

// SEO image fallback order: explicit SEO image -> cover -> first content image -> site default.
// This affects metadata only; it does not render a visual cover.
const firstContentImage = getFirstContentImage('writing', post.id, post.body);
const seoImage = post.data.seoImage ?? post.data.cover ?? firstContentImage;
const ogImageUrl = seoImage
  ? (await getImage({ src: seoImage, width: 1200 })).src
  : undefined;

const bodyClass = [
  'page-post',
  contentBackground ? 'has-content-bg' : '',
  themeColor ? 'has-theme-bg' : '',
]
  .filter(Boolean)
  .join(' ');

const bodyStyle = [
  contentBackground ? `--post-content-bg-url: url('${contentBackground}')` : '',
  themeColor ? `--post-theme-bg: ${themeColor}` : '',
  themeColorDark ? `--post-theme-bg-dark: ${themeColorDark}` : '',
]
  .filter(Boolean)
  .join('; ');
---

<Layout
  title={`${post.data.title} - ThangQT`}
  description={post.data.description || post.data.title}
  bodyClass={bodyClass}
  bodyStyle={bodyStyle || undefined}
  ogImage={ogImageUrl}
  ogType="article"
  publishedDate={post.data.date}
  modifiedDate={post.data.updated}
  tags={post.data.tags}
  jsonLdType="article"
  desktopTitle={post.data.title}
>
  <section class="col-content post-header" data-window-title={post.data.title}>
    <div class="post-header-content">
      <p class="post-page-date">{formatShortDate(post.data.date)}</p>
      <h1 class="post-page-title">{post.data.title}</h1>
    </div>
  </section>

  <aside
    class:list={['col-detail post-body', contentBackground ? 'has-content-bg' : '']}
    style={contentBackground ? `--post-content-bg-url: url('${contentBackground}')` : undefined}
  >
    <div class="post-mobile-header" aria-hidden="true">
      <p class="post-page-date">{formatShortDate(post.data.date)}</p>
      <p class="post-page-title">{post.data.title}</p>
    </div>
    {post.data.cover && (
      <figure class="post-cover">
        <Image src={post.data.cover} alt={post.data.title} />
      </figure>
    )}
    <article class="prose">
      <Content />
    </article>
  </aside>
</Layout>
