---
import Layout from '../../layouts/Layout.astro';
import {
  formatLinkDate,
  formatLinkKind,
  getHostnameLabel,
  getLinkTitle,
  getPublishedLinks,
  hasRenderableLinkBody,
  resolveVia,
} from '../../utils/links';

export async function getStaticPaths() {
  const { links } = await getPublishedLinks();

  return links.map((link) => ({
    params: { slug: link.slug },
    props: { link },
  }));
}

const { link } = Astro.props;
const { Content } = await link.render();
const { slugMap } = await getPublishedLinks();
const via = resolveVia(link.data.via, slugMap);
const hasBody = hasRenderableLinkBody(link);
const pageTitle = getLinkTitle(link);
const pageDescription = link.data.note || `Saved link to ${getHostnameLabel(link.data.url)}.`;
---

<Layout
  title={`${pageTitle} - Links - ThangQT`}
  description={pageDescription}
  publishedDate={link.data.date}
  tags={link.data.tags}
  ogType="website"
  desktopTitle={pageTitle}
>
  <section class="col-content post-header link-header link-summary-column" data-window-title={pageTitle}>
    <div class="post-header-content">
      <p class="post-page-date link-page-domain">
        <a href={link.data.url} class="link-inline" target="_blank" rel="noreferrer">
          <span>{getHostnameLabel(link.data.url)}</span>
        </a>
      </p>
      <h1 class="post-page-title">{pageTitle}</h1>

      <div class="link-detail-meta">
        {formatLinkKind(link.data.kind) && <span>{formatLinkKind(link.data.kind)}</span>}
        {formatLinkDate(link.data.date) && <span>{formatLinkDate(link.data.date)}</span>}
      </div>
    </div>
  </section>

  <aside class="col-detail post-body link-body link-detail-column">
    <div class="post-mobile-header" aria-hidden="true">
      <p class="post-page-date link-page-domain">
        <a href={link.data.url} class="link-inline" target="_blank" rel="noreferrer" tabindex="-1">
          <span>{getHostnameLabel(link.data.url)}</span>
        </a>
      </p>
      <p class="post-page-title">{pageTitle}</p>
    </div>

    <div class="link-detail-top">
      <div class="link-detail-meta-grid">
        {via.length > 0 && (
          <div class="link-detail-section">
            <h3>Via</h3>
            <p class="link-via link-via-detail">
              {via.map((item) => (
                <span class="link-via-item">
                  <a href={item.href} class="link-inline" target={item.type === 'external' ? '_blank' : undefined} rel={item.type === 'external' ? 'noreferrer' : undefined}>
                    {item.label}
                  </a>
                </span>
              ))}
            </p>
          </div>
        )}

        {link.data.tags && link.data.tags.length > 0 && (
          <div class="link-detail-section">
            <h3>Tags</h3>
            <ul class="link-tags" aria-label="Tags">
              {link.data.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          </div>
        )}

        {link.data.archiveUrl && (
          <div class="link-detail-section">
            <p class="link-via link-via-detail">
              <a href={link.data.archiveUrl} target="_blank" rel="noreferrer" class="link-inline link-archive-link">
                <span>Archive</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M7 17L17 7" />
                  <path d="M8 7h9v9" />
                </svg>
              </a>
            </p>
          </div>
        )}
      </div>

      {link.data.note && <p class="link-note link-note-detail link-note-main">{link.data.note}</p>}

    </div>

    {hasBody && (
      <article class="prose link-prose">
        <Content />
      </article>
    )}
  </aside>
</Layout>
