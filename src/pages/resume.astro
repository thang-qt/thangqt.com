---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Resume - ThangQT"
  description="Resume of Tô Quang Thắng, computer science student and full-stack developer."
>
  <section class="col-content resume-page" data-window-title="Resume">
    <article class="resume-sheet">
      <header class="resume-hero">
        <h1>Tô Quang Thắng</h1>
        <p>Full-stack developer · Computer science student · Hanoi, Vietnam</p>
      </header>

      <section class="resume-contact-line" aria-label="Resume contact links">
        <a href="mailto:thang@thangqt.com">thang@thangqt.com</a>
        <a href="tel:0387000902">+84 387 000 902</a>
        <a href="https://github.com/thang-qt" target="_blank" rel="noreferrer">github.com/thang-qt</a>
        <a href="/resume.pdf">PDF</a>
      </section>

      <main class="resume-main-flow">
        <section class="resume-intro">
          <p>
            I build practical web products end to end: backend APIs, frontends, automation scripts,
            auth flows, payment integrations, and deployment tooling. Comfortable in Linux-first
            development environments, with a preference for clean architecture and small, useful systems.
          </p>
        </section>

        <section class="resume-section">
          <h2>Experience</h2>
          <article class="resume-entry">
            <div class="resume-entry__meta">
              <time>Feb 2026 — Present</time>
              <span>BAP IT Co., JSC</span>
            </div>
            <div class="resume-entry__body">
              <h3>Full Stack Developer <span>Contract</span></h3>
              <ul>
                <li>Contributed to an internal online coding/interview platform: dashboard workflows, authentication, question bank management, and session management.</li>
                <li>Built JWT auth, role-based access control, candidate invite lifecycle, and execution-related backend/frontend surfaces.</li>
                <li>Integrated Judge0 multi-language code execution, prototyped Yjs/WebSocket collaboration, and set up Jest/Playwright testing.</li>
                <li>Built development tooling and CI workflows, including a Codeforces Parquet importer for bulk question-bank seeding.</li>
                <li>Implemented flows for client demo applications in healthcare and enterprise workflow domains.</li>
              </ul>
            </div>
          </article>
        </section>

        <section class="resume-section">
          <h2>Selected products</h2>
          <article class="resume-entry">
            <div class="resume-entry__meta">
              <a href="https://nganla.com" target="_blank" rel="noreferrer">nganla.com</a>
            </div>
            <div class="resume-entry__body">
              <h3>Ngàn Lá</h3>
              <p>Online exam platform for Vietnamese high school students with textbook mapping and analytics.</p>
              <ul>
                <li>Next.js, Go/Chi, shadcn/ui, grade/subject/chapter content structure.</li>
                <li>Automated crawlers and LLM-assisted bulk question generation/import.</li>
                <li>SePay QR payment flow with API/webhook confirmation.</li>
              </ul>
            </div>
          </article>

          <article class="resume-entry">
            <div class="resume-entry__meta">
              <a href="/projects/vocaxis">Project page</a>
            </div>
            <div class="resume-entry__body">
              <h3>Vocaxis</h3>
              <p>Vocabulary platform with AI-generated entries, translations, and FSRS spaced repetition.</p>
              <ul>
                <li>StarDict-compatible dictionary served through Cloudflare Workers/D1.</li>
                <li>Plasmo browser extension for context-aware vocabulary capture.</li>
                <li>Next.js/Supabase public launch with ~400 organic signups.</li>
              </ul>
            </div>
          </article>
        </section>

        <section class="resume-section">
          <h2>Skills</h2>
          <p class="resume-skill-line">
            C++ · Java · Python · JavaScript · TypeScript · Go · React · Next.js · NestJS · PostgreSQL · Supabase · Linux · Docker · Git · Nix · Cloudflare Workers
          </p>
        </section>

        <section class="resume-section">
          <h2>Education</h2>
          <article class="resume-entry resume-entry--compact">
            <div class="resume-entry__meta">
              <time>2023 — 2027</time>
            </div>
            <div class="resume-entry__body">
              <h3>VNU University of Engineering and Technology</h3>
              <p>Computer Science Degree · Hanoi, Vietnam</p>
            </div>
          </article>
        </section>

        <section class="resume-section">
          <h2>Languages</h2>
          <p class="resume-skill-line">Vietnamese — Native · English — Working proficiency</p>
        </section>
      </main>
    </article>
  </section>
</Layout>
