---
import Layout from '../layouts/Layout.astro';

// Sample projects - replace with your own
const projects = [
  {
    title: 'Project One',
    image: 'https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=800',
  },
  {
    title: 'Project Two',
    image: 'https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?w=800',
  },
  {
    title: 'Project Three',
    image: 'https://images.unsplash.com/photo-1615789591457-74a63395c990?w=800',
  },
];
---

<Layout title="ThangQT - Designer & Developer" description="Designer and Developer">
  <section class="col-main">
    <p>
      Hey, I'm ThangQT and I'm a designer and developer.
    </p>
    <p>
      I specialize in creating beautiful, functional web experiences using modern 
      technologies. I believe in clean design, thoughtful interactions, and building 
      things that make a difference.
    </p>
    <p>
      Check out some of my work, or explore my blog and projects.
    </p>
  </section>

  <aside class="col-sidebar">
    {projects.map((project) => (
      <div>
        <h2>{project.title}</h2>
        <figure>
          <picture>
            <img src={project.image} alt={project.title} loading="lazy" />
          </picture>
        </figure>
      </div>
    ))}
  </aside>
</Layout>

<script>
  // Random project display
  function initRandomProject() {
    const sidebar = document.querySelector('.col-sidebar');
    if (sidebar) {
      const projectDivs = sidebar.querySelectorAll('div');
      if (projectDivs.length > 0) {
        const randomIndex = Math.floor(Math.random() * projectDivs.length);
        projectDivs[randomIndex].classList.add('is-visible');
        
        // Remove other projects
        projectDivs.forEach((div, index) => {
          if (index !== randomIndex) {
            div.remove();
          }
        });
      }
    }
  }

  document.addEventListener('DOMContentLoaded', initRandomProject);
  document.addEventListener('astro:after-swap', initRandomProject);
</script>
