---
import Layout from '../layouts/Layout.astro';
import { desktopBackgroundPatterns, desktopThemePacks } from '../config/desktop';
---

<Layout title="Settings - ThangQT" description="Desktop shell settings and credits.">
  <section class="col-content settings-page" data-window-title="Settings">
    <header class="settings-hero">
      <h1>Settings</h1>
    </header>

    <div class="settings-sections">
      <!-- Section: Contrast Mode -->
      <section class="settings-panel" aria-labelledby="settings-mode">
        <div class="settings-panel-head">
          <h2 id="settings-mode">Mode</h2>
        </div>
        <div class="settings-segmented" role="radiogroup" aria-label="Color mode">
          <label>
            <input type="radio" name="desktop-mode" value="auto" data-settings-mode />
            <span>Auto</span>
          </label>
          <label>
            <input type="radio" name="desktop-mode" value="light" data-settings-mode />
            <span>Light</span>
          </label>
          <label>
            <input type="radio" name="desktop-mode" value="dark" data-settings-mode />
            <span>Dark</span>
          </label>
        </div>
      </section>

      <!-- Section: Theme Packs -->
      <section class="settings-panel settings-panel--packs" aria-labelledby="settings-packs">
        <div class="settings-panel-head">
          <h2 id="settings-packs">Theme Packs</h2>
        </div>
        <div class="settings-pack-grid">
          {
            desktopThemePacks.map((pack) => (
              <label class={`settings-pack settings-pack--${pack.id}`}>
                <input type="radio" name="desktop-theme-pack" value={pack.id} data-settings-pack />
                <span class="settings-pack__preview" aria-hidden="true">
                  {pack.colors && (
                    <span class="palette-strip">
                      {pack.colors.map((color) => (
                        <span
                          class="palette-swatch"
                          style={`background-color: ${color};`}
                          title={color}
                        />
                      ))}
                    </span>
                  )}
                </span>
                <span class="settings-pack__body">
                  <strong>{pack.label}</strong>
                  <small>{pack.note}</small>
                </span>
              </label>
            ))
          }
        </div>
      </section>

      <!-- Section: Background Pattern -->
      <section class="settings-panel settings-panel--patterns" aria-labelledby="settings-patterns">
        <div class="settings-panel-head">
          <h2 id="settings-patterns">Background Pattern</h2>
        </div>
        <div class="settings-pack-grid settings-pattern-grid">
          {
            desktopBackgroundPatterns.map((pattern) => (
              <label class={`settings-pack settings-pattern settings-pattern--${pattern.id}`}>
                <input
                  type="radio"
                  name="desktop-bg-pattern"
                  value={pattern.id}
                  data-settings-pattern
                />
                <span class="settings-pack__preview" aria-hidden="true" />
                <span class="settings-pack__body">
                  <strong>{pattern.label}</strong>
                  <small>{pattern.note}</small>
                </span>
              </label>
            ))
          }
        </div>
      </section>

      <!-- Section: Desktop Behavior -->
      <section class="settings-panel" aria-labelledby="settings-behavior">
        <div class="settings-panel-head">
          <h2 id="settings-behavior">Desktop Behavior</h2>
        </div>
        <label class="settings-toggle-row">
          <span class="settings-toggle-row__body">
            <strong>Restore windows</strong>
            <small>Reopen your saved windows when you reload or revisit the site.</small>
          </span>
          <span class="settings-switch">
            <input type="checkbox" data-settings-restore-windows />
            <span aria-hidden="true"></span>
          </span>
        </label>
      </section>

      <!-- Section: Challenge Unlock -->
      <section class="settings-panel settings-challenge-unlock" data-challenge-code hidden>
        <div class="settings-captcha-box">
          <label class="settings-captcha">
            <span class="settings-captcha__control">
              <input type="checkbox" data-challenge-captcha />
              <span class="settings-captcha__spinner" aria-hidden="true"></span>
            </span>
            <span>I am not a superhero near an outlet</span>
          </label>
          <div class="settings-captcha-box__brand" aria-hidden="true">
            <span>⚡</span>
            <small>reCAPTCHA-ish</small>
          </div>
        </div>
        <p class="settings-unlock-code" data-challenge-unlock hidden>
          Unlock code: <code>FUSE-404</code>
        </p>
      </section>

      <!-- Section: Credits -->
      <section class="settings-panel settings-about" aria-labelledby="settings-credits">
        <div class="settings-panel-head">
          <h2 id="settings-credits">Credits</h2>
          <p>Design inspiration for the desktop shell, chrome, and playful web-app feeling.</p>
        </div>
        <dl>
          <div>
            <dt>Poolsuite</dt>
            <dd>
              <a href="https://poolsuite.net/" target="_blank" rel="noreferrer">poolsuite.net</a>
            </dd>
          </div>
          <div>
            <dt>PostHog</dt>
            <dd><a href="https://posthog.com/" target="_blank" rel="noreferrer">posthog.com</a></dd>
          </div>
        </dl>
      </section>
    </div>
  </section>
</Layout>
