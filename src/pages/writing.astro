---
import Layout from '../layouts/Layout.astro';
import PaginationNav from '../components/PaginationNav.astro';
import { getCollection } from 'astro:content';
import { paginateItems } from '../utils/pagination';

const PAGE_SIZE = 40;

const posts = await getCollection('writing', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const paginatedPosts = paginateItems(sortedPosts, 1, PAGE_SIZE);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

---

<Layout title="Writing - ThangQT" description="My various thoughts on life, tech, and everything in between">
  <section class="col-content archive-page archive-page--writing" data-window-title="Writing">
    <header class="archive-hero">
      <h1>Writing</h1>
    </header>

    <div class="writing-ledger" aria-label="Writing archive">
      {paginatedPosts.items.map((post, index) => (
        <article class="ledger-row">
          <a href={`/writing/${post.slug}`} class="ledger-row__link">
            <div class="ledger-row__meta">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            </div>
            <div class="ledger-row__body">
              <h2>{post.data.title}</h2>
            </div>
          </a>
        </article>
      ))}
    </div>

    {paginatedPosts.totalPages > 1 && (
      <PaginationNav
        basePath="/writing"
        currentPage={paginatedPosts.currentPage}
        totalPages={paginatedPosts.totalPages}
        label="Writing pagination"
      />
    )}
  </section>
</Layout>
