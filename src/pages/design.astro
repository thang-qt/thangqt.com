---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Design System - ThangQT" description="Desktop OS design system, interaction rules, and component showcase.">
  <section class="design-system" data-window-title="Design System">
    <header class="design-system__intro">
      <p class="design-kicker">OS design guide · v2</p>
      <h1>Design System</h1>
      <p>
        A reference for the desktop shell — window behavior, typography, tokens, and all UI
        primitives. Built with the same tokens and constraints as every other app.
      </p>
    </header>

    <!-- Principles -->
    <section class="ds-panel" aria-labelledby="ds-principles">
      <div class="ds-section-head">
        <p class="design-kicker">Foundation</p>
        <h2 id="ds-principles">Principles</h2>
      </div>
      <div class="ds-grid ds-grid--three">
        <article>
          <h3>Shell First</h3>
          <p>Chrome, movement, persistence, and routing belong to the desktop system. Apps style content only.</p>
        </article>
        <article>
          <h3>Token Driven</h3>
          <p>Color, spacing, borders, and contrast resolve through shared CSS tokens. Theme packs swap tokens.</p>
        </article>
        <article>
          <h3>Responsive by Design</h3>
          <p>Desktop: floating windows. Tablet: stacked panels. Mobile: accordion stack with tap-to-expand.</p>
        </article>
      </div>
    </section>

    <!-- Window interaction rules -->
    <section class="ds-panel" aria-labelledby="ds-interaction">
      <div class="ds-section-head">
        <p class="design-kicker">Window manager</p>
        <h2 id="ds-interaction">Interaction Rules</h2>
      </div>
      <table class="ds-table">
        <tbody>
          <tr>
            <th scope="row">Top nav</th>
            <td>Open or focus the matching app window and update the URL.</td>
          </tr>
          <tr>
            <th scope="row">List details</th>
            <td>Writing, project, and link details open as separate document windows.</td>
          </tr>
          <tr>
            <th scope="row">Content links</th>
            <td>Internal links replace the current app by default; right-click exposes window choices.</td>
          </tr>
          <tr>
            <th scope="row">External links</th>
            <td>Leave normal browser behavior intact; external tabs from context menus.</td>
          </tr>
          <tr>
            <th scope="row">Viewport resize</th>
            <td>Floating windows nudge inward on resize so they stay within the work area. Width/height clamp if stage shrinks.</td>
          </tr>
          <tr>
            <th scope="row">Mobile (&lt; 768px)</th>
            <td>Windows collapse to title-bar strips. Tap a strip to expand it; the previous active window collapses.</td>
          </tr>
          <tr>
            <th scope="row">Tablet (768–1100px)</th>
            <td>Windows stack as fluid panels centered to 48rem max-width. No drag or resize.</td>
          </tr>
        </tbody>
      </table>
    </section>

    <!-- Typography -->
    <section class="ds-panel" aria-labelledby="ds-type">
      <div class="ds-section-head">
        <p class="design-kicker">Typography</p>
        <h2 id="ds-type">Type System</h2>
      </div>
      <div class="type-specimen">
        <div>
          <span>Display — Fraunces</span>
          <p class="type-specimen__display">Fraunces</p>
        </div>
        <div>
          <span>Interface — IBM Plex Sans</span>
          <p class="type-specimen__body">IBM Plex Sans keeps the desktop readable and alive.</p>
        </div>
        <div>
          <span>Mono — IBM Plex Mono</span>
          <p class="type-specimen__mono">IBM Plex Mono / command labels / status text / tags</p>
        </div>
      </div>
    </section>

    <!-- Primitive controls -->
    <section class="ds-panel" aria-labelledby="ds-components">
      <div class="ds-section-head">
        <p class="design-kicker">Components</p>
        <h2 id="ds-components">UI Primitives</h2>
      </div>

      <div class="ds-section-head">
        <p class="design-kicker">Buttons &amp; chips</p>
      </div>
      <div class="component-strip">
        <button class="ds-button" type="button">Default</button>
        <button class="ds-button ds-button--accent" type="button">Accent</button>
        <span class="ds-chip">Saved locally</span>
        <span class="ds-chip ds-chip--accent">Active</span>
        <span class="ds-badge">12</span>
        <span class="ds-badge ds-badge--accent">New</span>
        <kbd class="ds-kbd">⌘K</kbd>
        <kbd class="ds-kbd">Esc</kbd>
      </div>

      <div class="ds-section-head" style="margin-top: 1rem;">
        <p class="design-kicker">Status &amp; progress</p>
      </div>
      <div class="component-strip">
        <span class="ds-status ds-status--online">Online</span>
        <span class="ds-status ds-status--away">Away</span>
        <span class="ds-status ds-status--offline">Offline</span>
      </div>
      <div style="margin-top: 0.75rem; max-width: 20rem;">
        <div class="ds-progress">
          <div class="ds-progress__bar" style="width: 62%"></div>
        </div>
      </div>

      <div class="ds-section-head" style="margin-top: 1rem;">
        <p class="design-kicker">Tabs</p>
      </div>
      <nav class="ds-tabs" aria-label="Example tabs">
        <button class="ds-tab is-active" type="button" aria-selected="true">All</button>
        <button class="ds-tab" type="button" aria-selected="false">Writing</button>
        <button class="ds-tab" type="button" aria-selected="false">Projects</button>
        <button class="ds-tab" type="button" aria-selected="false">Links</button>
      </nav>

      <div class="ds-section-head" style="margin-top: 1rem;">
        <p class="design-kicker">Toggle</p>
      </div>
      <div class="component-strip">
        <label class="ds-toggle">
          <input type="checkbox" checked />
          <span class="ds-toggle__track"></span>
          Dark mode
        </label>
        <label class="ds-toggle">
          <input type="checkbox" />
          <span class="ds-toggle__track"></span>
          Notifications
        </label>
      </div>

      <div class="ds-section-head" style="margin-top: 1rem;">
        <p class="design-kicker">Divider</p>
      </div>
      <hr class="ds-divider">
      <hr class="ds-divider">OR</hr>

      <div class="ds-section-head" style="margin-top: 1rem;">
        <p class="design-kicker">Tooltip</p>
      </div>
      <div class="component-strip">
        <button class="ds-button" type="button" data-tooltip="Opens in current window">Open</button>
        <span class="ds-chip" data-tooltip="Saved to localStorage">Cached</span>
      </div>

      <div class="ds-section-head" style="margin-top: 1rem;">
        <p class="design-kicker">Empty state</p>
      </div>
      <div class="ds-empty">
        <span class="ds-empty__icon">✎</span>
        <p class="ds-empty__title">No posts yet</p>
        <p class="ds-empty__body">Add entries in <code>src/content/writing/</code> to populate this list.</p>
      </div>

      <div class="ds-section-head" style="margin-top: 1rem;">
        <p class="design-kicker">Skeleton</p>
      </div>
      <div style="display: grid; gap: 0.5rem; max-width: 24rem;">
        <span class="ds-skeleton" style="height: 1.6rem; width: 60%"></span>
        <span class="ds-skeleton"></span>
        <span class="ds-skeleton" style="width: 80%"></span>
      </div>

      <div class="ds-section-head" style="margin-top: 1rem;">
        <p class="design-kicker">Form fields</p>
      </div>
      <div class="ds-field">
        <label for="design-input">Text Field</label>
        <input id="design-input" value="Token-based input" />
      </div>
      <div class="ds-field">
        <label for="design-select">Select</label>
        <select id="design-select">
          <option>List view</option>
          <option>Grid view</option>
          <option>Compact view</option>
        </select>
      </div>
    </section>

    <!-- Color tokens -->
    <section class="ds-panel" aria-labelledby="ds-tokens">
      <div class="ds-section-head">
        <p class="design-kicker">Tokens</p>
        <h2 id="ds-tokens">Color Surface</h2>
      </div>
      <div class="token-grid">
        <span style="--swatch: var(--wm-background)">Background</span>
        <span style="--swatch: var(--wm-surface)">Surface</span>
        <span style="--swatch: var(--wm-content)">Content</span>
        <span style="--swatch: var(--wm-chrome)">Chrome</span>
        <span style="--swatch: var(--wm-raised)">Raised</span>
        <span style="--swatch: var(--wm-subtle)">Subtle</span>
        <span style="--swatch: var(--wm-accent)">Accent</span>
        <span style="--swatch: var(--wm-accent-soft)">Accent Soft</span>
      </div>
    </section>

  </section>
</Layout>
