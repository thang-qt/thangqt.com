---
import Layout from '../layouts/Layout.astro';
import PaginationNav from '../components/PaginationNav.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { paginateItems } from '../utils/pagination';

const PAGE_SIZE = 12;

const projects = await getCollection('projects', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const getSortKey = (value: string) => (value.includes('-') ? value : `${value}-00`);

// Sort by year/month descending
const sortedProjects = projects.sort((a, b) =>
  getSortKey(b.data.year).localeCompare(getSortKey(a.data.year))
);
const paginatedProjects = paginateItems(sortedProjects, 1, PAGE_SIZE);
---

<Layout title="Projects - ThangQT" description="Selected works and projects">
  <section class="col-content projects-page" data-window-title="Projects">
    <header class="projects-header">
      <p class="projects-kicker">Build archive</p>
      <h1>Projects</h1>
      <p class="projects-status">{paginatedProjects.totalItems} projects shipped and counting.</p>
    </header>

    <div class="projects-grid">
      {paginatedProjects.items.map((project) => (
        <article class="project-card">
          <a href={`/projects/${project.slug}`} class="project-card-link">
            <div class="project-card-cover-wrapper">
              {project.data.cover ? (
                <Image src={project.data.cover} alt={project.data.title} class="project-card-image" />
              ) : (
                <div class="project-card-placeholder">
                  <span class="project-placeholder-icon" aria-hidden="true">▦</span>
                </div>
              )}
              <span class="project-card-year">{project.data.year.slice(0, 4)}</span>
            </div>
            <div class="project-card-body">
              <h2 class="project-card-title">{project.data.title}</h2>
              {project.data.description && <p class="project-card-desc">{project.data.description}</p>}
            </div>
          </a>
        </article>
      ))}
    </div>

    {paginatedProjects.totalPages > 1 && (
      <PaginationNav
        basePath="/projects"
        currentPage={paginatedProjects.currentPage}
        totalPages={paginatedProjects.totalPages}
        label="Projects pagination"
      />
    )}
  </section>
</Layout>
