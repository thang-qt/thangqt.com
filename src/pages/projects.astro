---
import Layout from '../layouts/Layout.astro';

const projects = [
  { slug: 'ecommerce-platform', title: 'E-commerce Platform', date: '2025' },
  { slug: 'design-system', title: 'Design System Library', date: '2024' },
  { slug: 'portfolio-site', title: 'Portfolio Website', date: '2024' },
];
---

<Layout title="Projects - ThangQT" description="Selected works and projects">
  <section class="col-main">
    {projects.map((project) => (
      <article class="project-item">
        <a href={`/projects/${project.slug}`}>
          <h2 class="project-title">{project.title}</h2>
          <p class="project-meta">{project.date}</p>
        </a>
      </article>
    ))}
  </section>

  <aside class="col-sidebar">
    <div class="is-visible">
      <h2>Projects</h2>
    </div>
  </aside>
</Layout>
