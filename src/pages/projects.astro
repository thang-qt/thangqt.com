---
import Layout from '../layouts/Layout.astro';
import PaginationNav from '../components/PaginationNav.astro';
import { getCollection } from 'astro:content';
import { paginateItems } from '../utils/pagination';

const PAGE_SIZE = 8;

const projects = await getCollection('projects', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const getSortKey = (value) => (value.includes('-') ? value : `${value}-00`);

// Sort by year/month descending
const sortedProjects = projects.sort((a, b) =>
  getSortKey(b.data.year).localeCompare(getSortKey(a.data.year))
);
const paginatedProjects = paginateItems(sortedProjects, 1, PAGE_SIZE);
---

<Layout title="Projects - ThangQT" description="Selected works and projects">
  <section class="col-content list-app list-app--projects" data-window-title="Projects">
    <div class="list-mobile-header">
      <div>
        <p class="list-kicker">Build archive</p>
        <h1 class="list-page-title">Projects</h1>
      </div>
      <div class="list-toolbar" aria-label="Project display options">
        <span>View</span>
        <button type="button" data-list-view="list">List</button>
        <button type="button" data-list-view="grid">Grid</button>
        <button type="button" data-list-view="compact">Compact</button>
      </div>
    </div>
    <p class="list-status">{paginatedProjects.totalItems} projects sorted by ship date.</p>

    {paginatedProjects.items.map((project) => (
      <article class="project-item">
        <a href={`/projects/${project.slug}`} class="list-link">
          <span class="list-row-main">
            <h2 class="project-title">{project.data.title}</h2>
            {project.data.description && <p class="list-description">{project.data.description}</p>}
          </span>
          <span class="project-meta">{project.data.year.slice(0, 4)}</span>
        </a>
      </article>
    ))}

    <PaginationNav
      basePath="/projects"
      currentPage={paginatedProjects.currentPage}
      totalPages={paginatedProjects.totalPages}
      label="Projects pagination"
    />
  </section>

  <aside class="col-detail">
    <div class="is-visible">
      <h2>Projects</h2>
    </div>
  </aside>
</Layout>
