---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
// Sort by year descending
const sortedProjects = projects.sort((a, b) => parseInt(b.data.year) - parseInt(a.data.year));
---

<Layout title="Projects - ThangQT" description="Selected works and projects">
  <section class="col-main" transition:name="col-main" transition:animate="fade">
    <div class="list-mobile-header">
      <h1 class="list-page-title">Projects</h1>
    </div>
    {sortedProjects.map((project) => (
      <article class="project-item">
        <a href={`/projects/${project.slug}`} class="list-link">
          <h2 class="project-title">{project.data.title}</h2>
          <p class="project-meta">{project.data.year}</p>
        </a>
      </article>
    ))}
  </section>

  <aside class="col-sidebar" transition:name="col-sidebar" transition:animate="fade">
    <div class="is-visible">
      <h2>Projects</h2>
    </div>
  </aside>
</Layout>
