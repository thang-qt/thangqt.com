---
import Layout from '../layouts/Layout.astro';
import PaginationNav from '../components/PaginationNav.astro';
import { Image } from 'astro:assets';
import { getPublishedProjects } from '../utils/collections';
import { paginateItems, PROJECTS_PAGE_SIZE } from '../utils/pagination';
import { getFirstContentImage } from '../utils/contentImages';

const projects = await getPublishedProjects();
const paginatedProjects = paginateItems(projects, 1, PROJECTS_PAGE_SIZE);

const projectPalettes: Record<string, { bg: string; ink: string; accent: string }> = {
  tilia: { bg: '#edf7f4', ink: '#10231f', accent: '#2f7f6f' },
  kairos: { bg: '#eef3ff', ink: '#111827', accent: '#3b5bcc' },
  davplay: { bg: '#f3f0ea', ink: '#22180f', accent: '#8a5a25' },
  spanboard: { bg: '#f1eefb', ink: '#1f1833', accent: '#6d55b7' },
  nganla: { bg: '#eef8e9', ink: '#172411', accent: '#4c8a35' },
  vocaxis: { bg: '#f4fce3', ink: '#172018', accent: '#689f38' },
  mindform: { bg: '#fff0ea', ink: '#291710', accent: '#c46a43' },
};

function readableInk(hex: string | undefined) {
  if (!hex?.startsWith('#')) return 'var(--wm-ink)';
  const value = hex.slice(1);
  const full =
    value.length === 3
      ? value
          .split('')
          .map((char) => `${char}${char}`)
          .join('')
      : value;
  const r = parseInt(full.slice(0, 2), 16);
  const g = parseInt(full.slice(2, 4), 16);
  const b = parseInt(full.slice(4, 6), 16);
  const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
  return luminance > 0.62 ? '#101010' : '#fffaf0';
}

function getProjectPalette(project: (typeof projects)[number]) {
  const themeColor = project.data.themeColor;
  if (themeColor) {
    return {
      bg: themeColor,
      ink: readableInk(themeColor),
      accent: readableInk(themeColor),
    };
  }

  return (
    projectPalettes[project.slug] ?? {
      bg: 'var(--wm-subtle)',
      ink: 'var(--wm-ink)',
      accent: 'var(--wm-accent)',
    }
  );
}
---

<Layout title="Projects - ThangQT" description="Selected works and projects" windowBleed={true}>
  <section class="col-content archive-page archive-page--projects" data-window-title="Projects">
    <header class="archive-hero">
      <h1>Projects</h1>
    </header>

    <div class="project-color-stack" aria-label="Project archive">
      {
        paginatedProjects.items.map((project, index) => {
          const palette = getProjectPalette(project);
          const firstContentImage = getFirstContentImage('projects', project.id, project.body);
          const previewImage = project.data.cover ?? firstContentImage;
          return (
            <article
              class="project-color-section"
              style={`--project-bg: ${palette.bg}; --project-ink: ${palette.ink}; --project-accent: ${palette.accent};`}
            >
              <a
                href={`/projects/${project.slug}`}
                class="project-color-section__link"
                data-window-title={project.data.title}
              >
                <div class="project-color-section__copy">
                  <p class="project-color-section__meta">
                    <span>{String(index + 1).padStart(2, '0')}</span>
                    <span>{project.data.year}</span>
                  </p>
                  <h2>{project.data.title}</h2>
                  {project.data.description && <p>{project.data.description}</p>}
                  <span class="project-color-section__cta">Open project →</span>
                </div>

                <div class="project-color-section__visual">
                  {previewImage ? (
                    <Image src={previewImage} alt="" class="project-color-section__image" />
                  ) : (
                    <span aria-hidden="true">▦</span>
                  )}
                </div>
              </a>
            </article>
          );
        })
      }
    </div>

    {
      paginatedProjects.totalPages > 1 && (
        <PaginationNav
          basePath="/projects"
          currentPage={paginatedProjects.currentPage}
          totalPages={paginatedProjects.totalPages}
          label="Projects pagination"
        />
      )
    }
  </section>
</Layout>
