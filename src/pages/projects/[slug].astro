---
import Layout from '../../layouts/Layout.astro';
import { Image, getImage } from 'astro:assets';
import { getFirstContentImage } from '../../utils/contentImages';
import { getPublishedProjects } from '../../utils/collections';

export async function getStaticPaths() {
  const projects = await getPublishedProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const themeColor = project.data.themeColor;
const themeColorDark = project.data.themeColorDark;

const bodyClass = ['page-post', themeColor ? 'has-theme-bg' : '']
  .filter(Boolean)
  .join(' ');

const bodyStyle = [
  themeColor ? `--post-theme-bg: ${themeColor}` : '',
  themeColorDark ? `--post-theme-bg-dark: ${themeColorDark}` : '',
]
  .filter(Boolean)
  .join('; ');

// SEO image fallback order: explicit SEO image -> cover -> first content image -> site default.
// This affects metadata only; it does not render a visual cover.
const firstContentImage = getFirstContentImage('projects', project.id, project.body);
const seoImage = project.data.seoImage ?? project.data.cover ?? firstContentImage;
const ogImageUrl = seoImage
  ? (await getImage({ src: seoImage, width: 1200 })).src
  : undefined;
---

<Layout
  title={`${project.data.title} - ThangQT`}
  description={project.data.description || project.data.title}
  bodyClass={bodyClass}
  bodyStyle={bodyStyle || undefined}
  ogImage={ogImageUrl}
  desktopTitle={project.data.title}
>
  <section class="col-content post-header" data-window-title={project.data.title}>
    <div class="post-header-content">
      <p class="post-page-date">{project.data.year.slice(0, 4)}</p>
      <h1 class="post-page-title">{project.data.title}</h1>
    </div>
  </section>

  <aside class="col-detail post-body project-body">
    <div class="post-mobile-header" aria-hidden="true">
      <p class="post-page-date">{project.data.year.slice(0, 4)}</p>
      <p class="post-page-title">{project.data.title}</p>
    </div>
    {project.data.cover && (
      <figure class="post-cover">
        <Image src={project.data.cover} alt={project.data.title} />
      </figure>
    )}
    <article class="prose">
      <Content />
    </article>
  </aside>
</Layout>
