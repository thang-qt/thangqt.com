---
import Layout from '../../../layouts/Layout.astro';
import PaginationNav from '../../../components/PaginationNav.astro';
import { getCollection } from 'astro:content';
import { paginateItems } from '../../../utils/pagination';

const PAGE_SIZE = 8;

function getSortKey(value: string) {
  return value.includes('-') ? value : `${value}-00`;
}

export async function getStaticPaths() {
  const pageSize = 8;
  const projects = await getCollection('projects', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });

  const totalPages = Math.max(1, Math.ceil(projects.length / pageSize));

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => ({
    params: { page: String(index + 2) },
  }));
}

const currentPage = Number(Astro.params.page);

const projects = await getCollection('projects', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const sortedProjects = projects.sort((a, b) =>
  getSortKey(b.data.year).localeCompare(getSortKey(a.data.year))
);

const paginatedProjects = paginateItems(sortedProjects, currentPage, PAGE_SIZE);
---

<Layout title={`Projects - Page ${paginatedProjects.currentPage} - ThangQT`} description="Selected works and projects">
  <section class="col-content" transition:name="col-content" transition:animate="fade">
    <div class="list-mobile-header">
      <h1 class="list-page-title">Projects</h1>
    </div>

    {paginatedProjects.items.map((project) => (
      <article class="project-item">
        <a href={`/projects/${project.slug}`} class="list-link">
          <h2 class="project-title">{project.data.title}</h2>
          <p class="project-meta">{project.data.year.slice(0, 4)}</p>
        </a>
      </article>
    ))}

    <PaginationNav
      basePath="/projects"
      currentPage={paginatedProjects.currentPage}
      totalPages={paginatedProjects.totalPages}
      label="Projects pagination"
    />
  </section>

  <aside class="col-detail" transition:name="col-detail" transition:animate="fade">
    <div class="is-visible">
      <h2>Projects</h2>
    </div>
  </aside>
</Layout>
