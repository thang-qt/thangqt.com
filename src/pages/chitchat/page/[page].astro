---
import ChitchatFeed from '../../../components/ChitchatFeed.astro';
import PaginationNav from '../../../components/PaginationNav.astro';
import Layout from '../../../layouts/Layout.astro';
import { CHITCHAT_PAGE_SIZE, getMergedChitchatPosts } from '../../../utils/chitchat';
import { getPaginationStaticPaths, paginateItems, parsePageParam } from '../../../utils/pagination';

export async function getStaticPaths() {
  const chitchats = await getMergedChitchatPosts();
  return getPaginationStaticPaths(chitchats.length, CHITCHAT_PAGE_SIZE);
}

const chitchats = await getMergedChitchatPosts();
const currentPage = parsePageParam(Astro.params.page);
const paginatedChitchats = paginateItems(chitchats, currentPage, CHITCHAT_PAGE_SIZE);
---

<Layout title="Chitchat" description="Small posts, links, music, and what I’m making.">
  <ChitchatFeed posts={paginatedChitchats.items} />
  <PaginationNav
    basePath="/chitchat"
    currentPage={paginatedChitchats.currentPage}
    totalPages={paginatedChitchats.totalPages}
    label="Chitchat pagination"
  />
</Layout>
