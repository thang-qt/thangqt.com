---
import ChitchatFeed from '../../components/ChitchatFeed.astro';
import Layout from '../../layouts/Layout.astro';
import { getMergedChitchatPosts } from '../../utils/chitchat';

export async function getStaticPaths() {
  const chitchats = await getMergedChitchatPosts();

  return chitchats.map((post) => ({
    params: { slug: post.source === 'local' ? post.slug : post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const description =
  post.source === 'local'
    ? (post.post.body
        .split('\n')
        .find((line) => line.trim().length > 0)
        ?.trim() ?? 'Chitchat')
    : post.text || 'Bluesky chitchat post';
---

<Layout title="Chitchat" description={description}>
  <a href="/chitchat" class="chitchat-back" data-window-link data-window-title="Chitchat">
    ← all chitchat
  </a>
  <ChitchatFeed posts={[post]} />
</Layout>
