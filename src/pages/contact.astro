---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - ThangQT" description="Get in touch with me">
  <section class="col-main" transition:name="col-main" transition:animate="fade">
    <p>
      You can reach me directly via email at 
      <code class="email-obfuscated">thang at &lt;this domain&gt; dot com</code>
    </p>
    
    <p>
      Alternatively, if you prefer to stay anonymous or just want to send a quick 
      message, feel free to use the contact form below.
    </p>
    
    <form class="contact-form" id="contact-form">
      <div class="form-group">
        <label for="name">Name <span class="optional">(optional)</span></label>
        <input 
          type="text" 
          id="name" 
          name="name" 
          placeholder="Your name"
          autocomplete="name"
        />
      </div>
      
      <div class="form-group">
        <label for="contact-method">Contact Method <span class="optional">(optional)</span></label>
        <input 
          type="text" 
          id="contact-method" 
          name="contactMethod" 
          placeholder="Email, Twitter, etc. - if you'd like a reply"
        />
      </div>
      
      <div class="form-group">
        <label for="message">Message <span class="required">*</span></label>
        <textarea 
          id="message" 
          name="message" 
          rows="6" 
          placeholder="What's on your mind?"
          required
        ></textarea>
      </div>
      
      <div class="form-group turnstile-container">
        <div id="turnstile-widget"></div>
      </div>
      
      <button type="submit" class="submit-btn" id="submit-btn">
        <span class="btn-text">Send Message</span>
        <span class="btn-loading">Sending...</span>
      </button>
      
      <div class="form-status" id="form-status"></div>
    </form>
    
    <!-- Success overlay -->
    <div class="success-overlay" id="success-overlay">
      <div class="success-content">
        <div class="success-checkmark">
          <svg viewBox="0 0 52 52">
            <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none"/>
            <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
          </svg>
        </div>
        <p class="success-title">Message sent!</p>
        <p class="success-subtitle">Thanks for reaching out. I'll get back to you if needed.</p>
        <button type="button" class="success-dismiss" id="success-dismiss">Send another message</button>
      </div>
    </div>
  </section>

  <aside class="col-sidebar" transition:name="col-sidebar" transition:animate="fade">
    <div class="is-visible">
      <h2>Contact</h2>
    </div>
  </aside>
</Layout>

<style>
  .col-main {
    position: relative;
  }

  .contact-form {
    margin-top: calc(var(--margin) * 1.5);
    max-width: 500px;
  }
  
  .form-group {
    margin-bottom: calc(var(--margin) * 1.25);
  }
  
  .form-group label {
    display: block;
    font-size: var(--fs-caption);
    font-weight: 500;
    margin-bottom: calc(var(--margin) / 2);
    color: var(--fg-color);
  }
  
  .optional {
    color: var(--fg-color-medium);
    font-weight: 400;
  }
  
  .required {
    color: var(--fg-color);
  }
  
  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: calc(var(--margin) * 0.75);
    font-family: inherit;
    font-size: var(--fs-body);
    color: var(--fg-color);
    background-color: var(--fg-color-light);
    border: 1px solid var(--divider-color);
    border-radius: 6px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    cursor: none;
  }
  
  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--fg-color-medium);
  }
  
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--fg-color);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--fg-color) 10%, transparent);
  }
  
  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }
  
  .turnstile-container {
    min-height: 65px;
  }
  
  .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: calc(var(--margin) * 0.75) calc(var(--margin) * 1.5);
    font-family: inherit;
    font-size: var(--fs-body);
    font-weight: 500;
    color: var(--bg-color);
    background-color: var(--fg-color);
    border: 1px solid var(--fg-color);
    border-radius: 6px;
    cursor: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    position: relative;
  }
  
  .submit-btn:hover:not(:disabled) {
    opacity: 0.85;
  }
  
  .submit-btn:active:not(:disabled) {
    transform: scale(0.98);
  }
  
  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  
  .submit-btn .btn-loading {
    display: none;
  }
  
  .submit-btn.is-loading .btn-text {
    display: none;
  }
  
  .submit-btn.is-loading .btn-loading {
    display: inline;
  }
  
  .form-status {
    margin-top: var(--margin);
    font-size: var(--fs-caption);
    line-height: 1.5;
  }
  
  .form-status.success {
    color: hsl(142, 70%, 35%);
  }
  
  [data-theme="dark"] .form-status.success {
    color: hsl(142, 70%, 55%);
  }
  
  .form-status.error {
    color: hsl(0, 70%, 45%);
  }
  
  [data-theme="dark"] .form-status.error {
    color: hsl(0, 70%, 60%);
  }

  /* Email obfuscation styling */
  .email-obfuscated {
    font-family: 'SF Mono', 'Fira Code', 'Monaco', 'Consolas', monospace;
    font-size: 0.9em;
    background: var(--fg-color-light);
    padding: 0.2em 0.5em;
    border-radius: 4px;
  }

  /* Success overlay */
  .success-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-color);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .success-overlay.is-visible {
    opacity: 1;
    visibility: visible;
  }

  .success-content {
    text-align: center;
    transform: translateY(20px);
    opacity: 0;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease;
  }

  .success-overlay.is-visible .success-content {
    transform: translateY(0);
    opacity: 1;
    transition-delay: 0.1s;
  }

  .success-checkmark {
    width: 80px;
    height: 80px;
    margin: 0 auto calc(var(--margin) * 1.5);
  }

  .success-checkmark svg {
    width: 100%;
    height: 100%;
  }

  .checkmark-circle {
    stroke: var(--fg-color);
    stroke-width: 2;
    stroke-dasharray: 166;
    stroke-dashoffset: 166;
    stroke-linecap: round;
  }

  .success-overlay.is-visible .checkmark-circle {
    animation: stroke-circle 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
    animation-delay: 0.2s;
  }

  .checkmark-check {
    stroke: var(--fg-color);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
  }

  .success-overlay.is-visible .checkmark-check {
    animation: stroke-check 0.4s cubic-bezier(0.65, 0, 0.45, 1) forwards;
    animation-delay: 0.6s;
  }

  @keyframes stroke-circle {
    100% {
      stroke-dashoffset: 0;
    }
  }

  @keyframes stroke-check {
    100% {
      stroke-dashoffset: 0;
    }
  }

  .success-title {
    font-size: var(--fs-body-m);
    font-weight: 600;
    margin: 0 0 calc(var(--margin) / 2) 0;
    color: var(--fg-color);
  }

  .success-subtitle {
    font-size: var(--fs-body);
    color: var(--fg-color-medium);
    margin: 0 0 calc(var(--margin) * 1.5) 0;
    max-width: 280px;
  }

  .success-dismiss {
    font-family: inherit;
    font-size: var(--fs-caption);
    color: var(--fg-color-medium);
    background: none;
    border: none;
    cursor: none;
    padding: calc(var(--margin) / 2) var(--margin);
    border-radius: 4px;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .success-dismiss:hover {
    color: var(--fg-color);
    background-color: var(--fg-color-light);
  }
</style>

<script>
  // Contact form handling
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const formStatus = document.getElementById('form-status') as HTMLDivElement;
    const successOverlay = document.getElementById('success-overlay') as HTMLDivElement;
    const successDismiss = document.getElementById('success-dismiss') as HTMLButtonElement;
    
    if (!form || !submitBtn || !formStatus || !successOverlay) return;

    // Clone to remove old listeners
    const newForm = form.cloneNode(true) as HTMLFormElement;
    form.parentNode?.replaceChild(newForm, form);
    
    const newSubmitBtn = newForm.querySelector('#submit-btn') as HTMLButtonElement;
    const newFormStatus = newForm.querySelector('#form-status') as HTMLDivElement;

    // Show success overlay
    function showSuccess() {
      successOverlay.classList.add('is-visible');
    }

    // Hide success overlay
    function hideSuccess() {
      successOverlay.classList.remove('is-visible');
      // Reset the form
      newForm.reset();
      (window as any).turnstile?.reset();
    }

    // Dismiss button handler
    successDismiss?.addEventListener('click', hideSuccess);

    newForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Get form data
      const formData = new FormData(newForm);
      const message = formData.get('message') as string;
      
      if (!message?.trim()) {
        newFormStatus.textContent = 'Please enter a message.';
        newFormStatus.className = 'form-status error';
        return;
      }
      
      // Get Turnstile token
      const turnstileResponse = (window as any).turnstile?.getResponse();
      if (!turnstileResponse) {
        newFormStatus.textContent = 'Please complete the verification.';
        newFormStatus.className = 'form-status error';
        return;
      }
      
      // Show loading state
      newSubmitBtn.disabled = true;
      newSubmitBtn.classList.add('is-loading');
      newFormStatus.textContent = '';
      newFormStatus.className = 'form-status';
      
      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            name: formData.get('name'),
            contactMethod: formData.get('contactMethod'),
            message: message,
            turnstileToken: turnstileResponse,
          }),
        });
        
        const result = await response.json();
        
        if (response.ok) {
          // Show animated success overlay
          showSuccess();
        } else {
          throw new Error(result.error || 'Failed to send message');
        }
      } catch (error) {
        newFormStatus.textContent = error instanceof Error ? error.message : 'Something went wrong. Please try again.';
        newFormStatus.className = 'form-status error';
        // Reset Turnstile on error
        (window as any).turnstile?.reset();
      } finally {
        newSubmitBtn.disabled = false;
        newSubmitBtn.classList.remove('is-loading');
      }
    });
  }

  // Load Turnstile script
  function loadTurnstile() {
    if (document.querySelector('script[src*="turnstile"]')) return;
    
    const script = document.createElement('script');
    script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js?onload=onTurnstileLoad';
    script.async = true;
    script.defer = true;
    document.head.appendChild(script);
    
    // Turnstile callback
    (window as any).onTurnstileLoad = () => {
      const container = document.getElementById('turnstile-widget');
      if (container && !(container as any)._rendered) {
        (window as any).turnstile.render('#turnstile-widget', {
          // Use test key for local development, replace with real key in production
          sitekey: '0x4AAAAAACMDyYIwIxhAdJZX', // Visible test key (always passes)
          theme: document.documentElement.getAttribute('data-theme') || 'light',
        });
        (container as any)._rendered = true;
      }
    };
  }

  // Re-render Turnstile on theme change
  function setupThemeObserver() {
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === 'data-theme') {
          const container = document.getElementById('turnstile-widget');
          if (container && (window as any).turnstile) {
            container.innerHTML = '';
            (container as any)._rendered = false;
            (window as any).turnstile.render('#turnstile-widget', {
              sitekey: '0x4AAAAAACMDyYIwIxhAdJZX',
              theme: document.documentElement.getAttribute('data-theme') || 'light',
            });
            (container as any)._rendered = true;
          }
        }
      });
    });
    
    observer.observe(document.documentElement, { attributes: true });
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', () => {
    initContactForm();
    loadTurnstile();
    setupThemeObserver();
  });

  // Re-initialize after view transitions
  document.addEventListener('astro:after-swap', () => {
    initContactForm();
    // Re-render turnstile if on contact page
    const container = document.getElementById('turnstile-widget');
    if (container && (window as any).turnstile) {
      container.innerHTML = '';
      (container as any)._rendered = false;
      (window as any).turnstile.render('#turnstile-widget', {
        sitekey: '0x4AAAAAACMDyYIwIxhAdJZX',
        theme: document.documentElement.getAttribute('data-theme') || 'light',
      });
      (container as any)._rendered = true;
    }
  });
</script>
