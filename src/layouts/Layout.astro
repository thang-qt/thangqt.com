---
import SEO from '../components/SEO.astro';
import JsonLD from '../components/JsonLD.astro';
import DesktopWindow from '../components/DesktopWindow.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import {
  desktopApps,
  desktopBackgroundPatterns,
  desktopNavItems,
  desktopPinnedItems,
  desktopProfile,
  desktopThemePacks,
  getDesktopAppForPath,
  getDesktopAppKeyForPath,
} from '../config/desktop';
import '../styles/main.css';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  bodyStyle?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  publishedDate?: Date;
  modifiedDate?: Date;
  tags?: string[];
  jsonLdType?: 'website' | 'article' | 'person';
  desktopTitle?: string;
  windowBleed?: boolean;
}

const {
  title = 'ThangQT',
  description = 'Open-source developer and Linux enthusiast',
  bodyClass = '',
  bodyStyle = '',
  ogImage,
  ogType = 'website',
  publishedDate,
  modifiedDate,
  tags = [],
  jsonLdType = 'website',
  desktopTitle,
  windowBleed = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const currentPage = getDesktopAppForPath(currentPath);
const windowTitle = desktopTitle ?? currentPage?.label ?? 'ThangQT';
const initialAppKey = getDesktopAppKeyForPath(currentPath);
const initialWindow = currentPage.window;

const [llmProjects, llmWriting] = await Promise.all([
  getCollection('projects', ({ data }) => import.meta.env.PROD ? data.draft !== true : true),
  getCollection('writing', ({ data }) => import.meta.env.PROD ? data.draft !== true : true),
]);

const llmChatContext = {
  projects: llmProjects
    .sort((a, b) => String(b.data.year).localeCompare(String(a.data.year)))
    .map((project) => ({
      title: project.data.title,
      year: project.data.year,
      description: project.data.description,
      href: `/projects/${project.slug}`,
    })),
  writing: llmWriting
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .map((post) => ({
      title: post.data.title,
      date: post.data.date.toISOString().slice(0, 10),
      description: post.data.description,
      href: `/writing/${post.slug}`,
    })),
};
---

<!DOCTYPE html>
<html lang="en" data-theme="light" data-color-mode="light" data-theme-pack="poolsuite" data-bg-pattern="grid">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..800&family=IBM+Plex+Mono:wght@400;500;700&family=IBM+Plex+Sans:wght@400;500;700&display=swap" rel="stylesheet" />

    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      publishedDate={publishedDate}
      modifiedDate={modifiedDate}
      tags={tags}
    />

    <JsonLD
      type={jsonLdType}
      title={title}
      description={description}
      image={ogImage}
      publishedDate={publishedDate}
      modifiedDate={modifiedDate}
      tags={tags}
    />

    <link rel="alternate" type="application/rss+xml" title="ThangQT's Blog" href="/rss.xml" />
    <script is:inline>
      const mode = localStorage.getItem('desktop-color-mode') || 'light';
      const savedPack = localStorage.getItem('desktop-theme-pack') || 'poolsuite';
      const pack = savedPack === 'oxide' ? 'bloom' : savedPack;
      const savedPattern = localStorage.getItem('desktop-bg-pattern') || 'grid';
      // Migrate removed patterns to their closest replacement
      const patternMap = { tiles: 'grid', rings: 'dots' };
      const pattern = patternMap[savedPattern] || savedPattern;
      if (savedPack === 'oxide') localStorage.setItem('desktop-theme-pack', 'bloom');
      if (patternMap[savedPattern]) localStorage.setItem('desktop-bg-pattern', pattern);
      document.documentElement.dataset.colorMode = mode;
      document.documentElement.dataset.themePack = pack;
      document.documentElement.dataset.bgPattern = pattern;
    </script>
  </head>

  <body class={`ly-default desktop-os ${bodyClass}`.trim()} style={bodyStyle || undefined}>
    <div class="desktop-bg" aria-hidden="true"></div>

    <header class="desktop-menu">
      <a href="/" class="desktop-menu__brand" aria-label="Open app launcher" data-launcher-open>
        <span class="desktop-menu__brand-icon" aria-hidden="true"></span>
        <strong>ThangQT</strong>
      </a>
      <nav class="desktop-menu__nav" aria-label="Main navigation">
        {desktopPinnedItems.map((item) => (
          <a
            href={item.href}
            data-window-link
            data-window-title={item.label}
            aria-current={currentPath === item.href || (item.href !== '/' && currentPath.startsWith(`${item.href}/`)) ? 'page' : undefined}
          >
            <span class="desktop-menu__nav-icon" aria-hidden="true">
              {item.iconName ? <Icon name={item.iconName} /> : item.icon}
            </span>
            {item.label}
          </a>
        ))}
      </nav>
      <div class="desktop-menu__status">
        <span class="desktop-menu__date" data-desktop-date>WED 3 JUN</span>
        <span class="desktop-menu__clock" data-desktop-clock>19:37</span>
      </div>
    </header>

    <main class="desktop-stage">
      <DesktopWindow
        title={windowTitle.toUpperCase()}
        class={`desktop-window--site desktop-window--app-${initialAppKey}`}
        variant="paper"
        minWidth={initialWindow.minWidth}
        minHeight={initialWindow.minHeight}
        data-window-url={currentPath}
        data-window-app={initialAppKey}
        data-window-bleed={windowBleed ? 'true' : undefined}
        data-window-base-app={currentPage.id}
        data-window-flags={windowBleed ? 'bleed' : undefined}
        style={`width: ${initialWindow.width}; height: ${initialWindow.height};`}
      >
        <div class="desktop-document">
          <slot />
        </div>
      </DesktopWindow>

      <DesktopWindow
        title="PROFILE"
        class="desktop-window--profile"
        variant="mini"
        minWidth={260}
        minHeight={220}
        resizable={false}
        maximizable={false}
      >
        <div class="profile-card">
          <div class="profile-card__avatar" aria-hidden="true">TQ</div>
          <div>
            <p class="profile-card__name">{desktopProfile.name}</p>
            <p class="profile-card__handle">@{desktopProfile.handle}</p>
          </div>
        </div>
        <p class="profile-card__tagline">{desktopProfile.tagline}</p>
        <dl class="profile-card__meta">
          <div>
            <dt>Role</dt>
            <dd>{desktopProfile.role}</dd>
          </div>
          <div>
            <dt>Base</dt>
            <dd>{desktopProfile.location}</dd>
          </div>
        </dl>
        <div class="profile-card__links">
          {desktopProfile.links.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </div>
      </DesktopWindow>

    </main>

    <div class="desktop-icon-templates" hidden aria-hidden="true">
      {desktopNavItems.map((item) => (
        item.iconName && (
          <template data-app-icon-template={item.id}>
            <Icon name={item.iconName} />
          </template>
        )
      ))}
      <template data-window-control-icon-template="chat-clear">
        <Icon name="ph:broom" />
      </template>
    </div>

    <div class="desktop-launcher" data-launcher hidden>
      <button class="desktop-launcher__backdrop" type="button" data-launcher-backdrop aria-label="Close launcher"></button>
      <section class="desktop-launcher__panel" role="dialog" aria-label="App launcher">
        <div class="desktop-launcher__search">
          <span aria-hidden="true">⌕</span>
          <input type="search" placeholder="Search apps…" autocomplete="off" spellcheck="false" data-launcher-input />
          <kbd>Alt Space</kbd>
        </div>
        <div class="desktop-launcher__list" role="listbox" data-launcher-list></div>
      </section>
    </div>

    <aside class="desktop-shortcuts" data-shortcuts-helper hidden aria-label="Keyboard shortcuts">
      <header>
        <h2>Shortcuts</h2>
        <button type="button" data-shortcuts-close aria-label="Close shortcuts">×</button>
      </header>
      <dl>
        <div><dt><kbd>Alt</kbd> <kbd>Space</kbd></dt><dd>Open app launcher</dd></div>
        <div><dt><kbd>?</kbd></dt><dd>Toggle this helper</dd></div>
        <div><dt><kbd>J</kbd> <kbd>K</kbd></dt><dd>Select list item, or scroll page</dd></div>
        <div><dt><kbd>H</kbd> <kbd>L</kbd></dt><dd>Scroll active window sideways</dd></div>
        <div><dt><kbd>Enter</kbd></dt><dd>Open selected item/app</dd></div>
        <div><dt><kbd>Alt</kbd> <kbd>H/J/K/L</kbd></dt><dd>Focus window by direction</dd></div>
        <div><dt><kbd>Alt</kbd> <kbd>Shift</kbd> <kbd>H/J/K/L</kbd></dt><dd>Move active window</dd></div>
        <div><dt><kbd>Alt</kbd> <kbd>Ctrl</kbd> <kbd>H/J/K/L</kbd></dt><dd>Resize active window</dd></div>
        <div><dt><kbd>Alt</kbd> <kbd>Q</kbd></dt><dd>Quit active window</dd></div>
        <div><dt><kbd>Alt</kbd> <kbd>M</kbd></dt><dd>Minimize active window</dd></div>
        <div><dt><kbd>Alt</kbd> <kbd>F</kbd></dt><dd>Maximize active window</dd></div>
        <div><dt><kbd>Alt</kbd> <kbd>1–7</kbd></dt><dd>Open app by topbar order</dd></div>
        <div><dt><kbd>Esc</kbd></dt><dd>Close launcher/helper</dd></div>
      </dl>
    </aside>

    <script is:inline define:vars={{ desktopThemePacks, desktopBackgroundPatterns, desktopApps, llmChatContext }}>
      window.__DESKTOP_THEME_PACKS = desktopThemePacks;
      window.__DESKTOP_BG_PATTERNS = desktopBackgroundPatterns;
      window.__DESKTOP_APPS = desktopApps;
      window.__LLM_CHAT_CONTEXT = llmChatContext;
    </script>

    <script>
      import '../scripts/desktop/index.js';
    </script>
  </body>
</html>
